# Python runtime artifacts
__pycache__/
*.py[cod]
.pytest_cache/

# Local scratch files produced by tests, doc rendering, and experiments
.tmp/

# Large generated retrieval artifacts. Rebuild them locally with scripts/build_index.
outputs/indexes/*
!outputs/indexes/.gitkeep
outputs/semantic/*
!outputs/semantic/.gitkeep
outputs/runs/*/indexes/
outputs/smoke/

# Local environment files
.env
.venv/

# Office temporary lock files
~$*.docx

# Root-level thesis artifacts kept out of the GitHub repository
/面向用户需求理解的商品评论反馈语义检索增强研究-完成版.docx
/面向用户需求理解的商品评论反馈语义检索增强研究.docx
/面向用户需求理解的商品评论反馈语义检索增强研究参考.docx
