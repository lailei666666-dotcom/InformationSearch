# Python runtime artifacts
__pycache__/
*.py[cod]
.pytest_cache/

# Local scratch files produced by tests and experiments
.tmp/

# Generated data and retrieval artifacts. Rebuild them locally with scripts.
data/processed/*.csv
data/raw/*_summary.json
outputs/indexes/*
!outputs/indexes/.gitkeep
outputs/semantic/*
!outputs/semantic/.gitkeep
outputs/runs/*
!outputs/runs/.gitkeep
outputs/smoke/

# Local environment files
.env
.venv/

# Office documents and temporary lock files kept out of the GitHub repository
~$*.docx
/*.docx
